# RASPUTIN Memory System — Environment Configuration
# Copy to .env and adjust values for your setup.

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=second_brain

# FalkorDB Knowledge Graph
FALKORDB_HOST=localhost
FALKORDB_PORT=6380
FALKORDB_GRAPH=brain

# Embedding Service
# Provider: ollama (default), openai, voyage, cohere
EMBED_PROVIDER=ollama
EMBED_URL=http://localhost:11434/api/embed
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# Neural Reranker (optional — system works without it, ~10-15% quality loss)
# Provider: local (default), cohere, jina, or set RERANKER_ENABLED=false to skip
RERANKER_ENABLED=true
RERANKER_PROVIDER=local
RERANKER_URL=http://localhost:8006/rerank
# RERANKER_MODEL=rerank-english-v3.0

# LLM for A-MAC quality scoring and consolidation
# Provider: ollama (default), openai, openrouter
LLM_PROVIDER=ollama
LLM_API_URL=http://localhost:11434/v1/chat/completions
LLM_MODEL=llama3:8b  # Any OpenAI-compatible model

# Workspace path (for consolidator.py memory mode)
WORKSPACE_PATH=./workspace

# BrainBox database location
BRAINBOX_DB=./brainbox/brainbox.db

# Ollama base URL (used by some tools directly)
# OLLAMA_URL=http://localhost:11434

# A-MAC LLM URL (optional — falls back to LLM_API_URL)
# Set to an OpenAI-compatible chat completions endpoint
# AMAC_LLM_URL=http://localhost:11434/v1/chat/completions

# Session transcripts directory (for consolidator + fact extractor)
# SESSIONS_DIR=./sessions

# Memory API URL (for consolidator to commit facts)
# MEMORY_API_URL=http://localhost:7777

# Optional: set to require auth on all API endpoints
# MEMORY_API_TOKEN=your-secret-token-here

# Known entities config file path
# KNOWN_ENTITIES_PATH=config/known_entities.json

# A-MAC model and reject log
# AMAC_MODEL=llama3:8b
# AMAC_REJECT_LOG=./logs/amac_rejected.log

# Feature flags
# DISABLE_FALKORDB=true

# Reranker extras (optional)
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_PORT=8006

# MCP Server name (optional — for memory-mcp-server.py)
# MCP_SERVER_NAME=rasputin-memory

# GPU device for embedding server
# CUDA_VISIBLE_DEVICES=1

# ─── Cloud API Keys (if using cloud providers) ─────────────────────────
# See docs/CLOUD_PROVIDERS.md for setup guides
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-v1-...
# COHERE_API_KEY=...
# VOYAGE_API_KEY=pa-...
# JINA_API_KEY=jina_...
