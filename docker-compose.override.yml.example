# Example overrides for production deployment
# Copy to docker-compose.override.yml and customize

services:
  qdrant:
    # Increase memory limit for large collections
    deploy:
      resources:
        limits:
          memory: 4G
    # Persist to host directory instead of Docker volume
    # volumes:
    #   - ./data/qdrant:/qdrant/storage

  falkordb:
    deploy:
      resources:
        limits:
          memory: 512M
